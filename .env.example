# Copy to .env and fill in. The .env file is gitignored.
# NEVER commit real values. Secrets live here (local) or in the host's env vars.

# Required: OpenAI API key used by the triage backend (backend/scanner.py)
OPENAI_API_KEY=sk-...
# Optional: override the model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: Supabase persistence (server-side only). Leave unset to run in
# demo-only mode. The service-role key bypasses RLS — keep it secret, never
# put it in frontend code.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── KYB & UK Sanctions Intelligence module (backend/kyb) ──
# Companies House Public Data API key (SERVER ONLY). Without it the module serves
# recorded fixtures from data/ch_fixtures/ so the demo runs offline.
COMPANIES_HOUSE_API_KEY=your_companies_house_rest_api_key
# Path to the UK Sanctions List XML. Without it the module falls back to the
# committed 30-designation sample at tests/kyb/fixtures/uksl_sample.xml.
# Download the full list from the FCDO "UK Sanctions List" page on GOV.UK.
UKSL_XML_PATH=inputs/UK-Sanctions-List.xml
